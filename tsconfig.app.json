{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "outDir": "dist",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "sourceMap": false,
    "moduleResolution": "bundler",
    "allowJs": false,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "removeComments": false,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@hujie/*": [
        "packages/*"
      ],
      "@hujie/components": [
        "packages/components"
      ],
      "@hujie/components/*": [
        "packages/components/*"
      ],
      "@hujie/utils": [
        "packages/utils"
      ],
      "@hujie/utils/*": [
        "packages/utils/*"
      ],
      "@hujie/theme-chalk": [
        "packages/theme-chalk"
      ],
      "@hujie/theme-chalk/*": [
        "packages/theme-chalk/*"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "packages/**/*.vue",
    "packages/**/*.d.ts",
    "docs/**/*.ts",
    "docs/**/*.vue",
    "docs/.vitepress/theme/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}

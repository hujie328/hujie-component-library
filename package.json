{
  "name": "hujie-component-library",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json",
    "docs:dev": "vitepress dev docs --host 0.0.0.0",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host 0.0.0.0",
    "test": "vitest"
  },
  "dependencies": {
    "@vue/shared": "^3.5.18",
    "echarts": "^6.0.0",
    "highcharts": "^11.4.8",
    "vue": "^3.5.18"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "rimraf": "^6.0.1",
    "sass": "^1.90.0",
    "typescript": "~5.8.3",
    "vite": "^7.1.0",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^3.0.8",
    "vitepress": "2.0.0-alpha.12",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "packageManager": "pnpm@10.19.0"
}
